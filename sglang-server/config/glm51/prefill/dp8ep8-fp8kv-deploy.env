# Server Base Info
SERVER_PORT=30000
BASE_GPU_ID=0

# Worker Info
# 与文件路径名保持一致
MODEL_NAME=glm51
WORKER_TYPE=prefill
CONFIG_FILENAME=dp8ep8-fp8kv-sgl-config.yaml

# Docker Run Info
DOCKER_IMAGE=lmsysorg/sglang:v0.5.10.post1
DOCKER_CONTAINER_NAME=${MODEL_NAME}-${WORKER_TYPE}-${SERVER_PORT}
MODEL_WEIGHT_PATH=$HOME/workspace



# # Multi Node Config
# # 注意：只有在多节点推理时才需要以下环境变脸，若无需此类环境变量，请注释。
# NODE_RANK=0
# NNODES=2
# DIST_INIT_ADDR=172.26.168.30:45000

# # SGLang Launch Server ENV
# # 注意：只有加"export"的环境变量才能被SGLang服务读取。若无需此类环境变量，请注释。
# export GLOO_SOCKET_IFNAME=enp86s0f0 
# export NCCL_SOCKET_IFNAME=enp86s0f0 
# export SGLANG_SCHEDULER_SKIP_ALL_GATHER=1 
# export SGLANG_ENABLE_SPEC_V2=1 
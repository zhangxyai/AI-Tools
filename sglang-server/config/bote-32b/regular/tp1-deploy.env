# Server Base Info
SERVER_PORT=30000
BASE_GPU_ID=0

# Worker Info
# 与文件路径名保持一致
MODEL_NAME=bote-32b
WORKER_TYPE=regular
CONFIG_FILENAME=tp1-sgl-config.yaml

# Docker Run Info
DOCKER_IMAGE=lmsysorg/sglang:v0.5.9
DOCKER_CONTAINER_NAME=${MODEL_NAME}-${WORKER_TYPE}-${SERVER_PORT}
MODEL_WEIGHT_PATH=/data
